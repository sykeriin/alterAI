# =============================================================================
# ALTER environment — copy to `.env` and fill in secrets locally.
# Used by: docker compose (backend services), NOT read by Flutter at runtime.
#
# Flutter uses --dart-define or in-app Settings for gateway/Supabase keys.
# Never commit a filled-in `.env` file.
# =============================================================================

# --- Public gateway (optional — leave empty for offline-only phone use) ---
ALTER_API_BASE_URL=
ALTER_GATEWAY_ENV=local
ALTER_API_GATEWAY_URL=http://localhost:8060
ALTER_VOICE_GATEWAY_URL=http://localhost:8070

# --- Sarvam AI (STT, TTS, translate, multilingual chat) ---
SARVAM_API_KEY=
SARVAM_API_BASE_URL=https://api.sarvam.ai
ALTER_MULTILINGUAL_PROVIDER=sarvam
ALTER_DEFAULT_LANGUAGE_CODE=en-IN
ALTER_SARVAM_TTS_MODEL=bulbul:v2
ALTER_SARVAM_STT_MODEL=saarika:v2.5

# --- Supabase (auth, profiles, edge functions) ---
# Flutter: pass at build/run time only:
#   flutter run --dart-define=SUPABASE_URL=https://YOUR_PROJECT.supabase.co
#   flutter run --dart-define=SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=

# --- OpenAI / Groq (optional cloud backends) ---
OPENAI_API_KEY=
GROQ_API_KEY=
ALTER_OPENAI_MODEL=gpt-4.1

# --- Local docker-only service URLs ---
ALTER_CLONE_COUNCIL_ENV=local
ALTER_FUTURE_SIMULATION_ENV=local
ALTER_MEMORY_ENV=local
ALTER_DATABASE_URL=postgresql://alter:alter@localhost:5432/alter
ALTER_OPPORTUNITY_ENV=local
ALTER_FIRECRAWL_API_KEY=
ALTER_FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1
ALTER_SOCIAL_GRAPH_ENV=local
ALTER_NEO4J_URI=neo4j://localhost:7687
ALTER_NEO4J_USER=neo4j
ALTER_NEO4J_PASSWORD=change-me
ALTER_NEO4J_DATABASE=neo4j
ALTER_CLONE_COUNCIL_URL=http://localhost:8080
ALTER_FUTURE_SIMULATION_URL=http://localhost:8090
ALTER_MEMORY_SYSTEM_URL=http://localhost:8100
ALTER_OPPORTUNITY_ENGINE_URL=http://localhost:8110
ALTER_SOCIAL_GRAPH_URL=http://localhost:8120
ALTER_LENS_URL=http://localhost:8130
ALTER_LENS_ENV=local
ALTER_LENS_OPENAI_MODEL=gpt-4.1-mini
ALTER_LENS_MAX_UPLOAD_MB=12
ALTER_REPUTATION_ENGINE_URL=http://localhost:8140
ALTER_REPUTATION_ENV=local
ALTER_REPUTATION_BASELINE_SCORE=600
ALTER_OFFICEKIT_URL=http://localhost:8150
ALTER_OFFICEKIT_ENV=local
ALTER_VOICE_ENV=local
ALTER_WAKE_PHRASE=hey alter
