FROM python:3.12-slim

ARG SERVICE_DIR

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY ${SERVICE_DIR}/pyproject.toml /app/pyproject.toml
COPY ${SERVICE_DIR}/README.md /app/README.md
COPY ${SERVICE_DIR}/src /app/src

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -e .

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "alter_api_gateway.api:app", "--host", "0.0.0.0", "--port", "8000"]
